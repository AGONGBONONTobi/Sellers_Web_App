generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id           String   @id @default(cuid())
  businessName String
  whatsapp     String
  location     String
  category     String
  exported     exported Boolean @default(false)
  createdAt    DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}